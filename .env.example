# ─────────────────────────────────────────────────────────────────────────────
# Puritan Insurance Agency — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Server-side only — never expose to client

# ── M-Pesa Daraja 3.0 ─────────────────────────────────────────────────────────
# Register at: https://developer.safaricom.co.ke
# Sandbox:  Use the test credentials from the Daraja portal
# Production: Use credentials from your approved Go-Live app
MPESA_ENVIRONMENT=sandbox                               # "sandbox" | "production"
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                                  # Sandbox: 174379 | Production: your Paybill/Till
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey         # From Daraja portal under your app
# Callback must be a publicly reachable HTTPS URL — cannot be localhost.
# For local dev: npx ngrok http 3000
# Then set MPESA_CALLBACK_URL=https://<ngrok-id>.ngrok-free.app/api/payments/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/payments/mpesa/callback

# ── Resend (email receipts & notifications) ───────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.co.ke        # Must be from your verified Resend domain
EMAIL_REPLY_TO=info@yourdomain.co.ke       # Agency inbox that receives notifications

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Get from: https://sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Support ───────────────────────────────────────────────────────────────────
SUPPORT_PHONE=+254 700 000 000             # Shown in payment receipt emails

# ── Optional Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# Puritan Insurance Agency — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Server-side only — never expose to client

# ── Paystack ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys & Webhooks
# Test keys start with pk_test_ / sk_test_
# Live keys start with pk_live_ / sk_live_
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here   # Safe to expose — used in browser popup
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here               # Server-side only — NEVER expose to client

# Webhook must be a publicly reachable HTTPS URL.
# Set this in Paystack Dashboard → Settings → API Keys & Webhooks → Webhook URL
# For local dev, use: npx ngrok http 3000
# Then set: PAYSTACK_WEBHOOK_URL=https://<ngrok-id>.ngrok-free.app/api/payments/paystack/webhook
PAYSTACK_WEBHOOK_URL=https://yourdomain.co.ke/api/payments/paystack/webhook

# ── Resend (email receipts) ───────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Verify your sending domain in Resend before going to production
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.co.ke                     # Must be from your verified Resend domain
EMAIL_REPLY_TO=info@yourdomain.co.ke

# ── Optional Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
